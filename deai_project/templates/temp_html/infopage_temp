function renderItemTree(item) {
  const treeEl = document.getElementById('im-tree');
  if (!item.from_ids || item.from_ids.length === 0) {
    treeEl.innerHTML = '<div style="font-size:12px;color:var(--text-muted);text-align:center;padding:20px 0;">재료 정보 없음</div>';
    return;
  }

  const mats    = item.from_ids.map(_getItem);
  const subMats = mats.map(m => (m.from_ids||[]).map(_getItem));
  const hasSub  = subMats.some(a => a.length > 0);

  // 재료 그룹 열 
  const matCols = mats.map((mat, i) => {
    const lv2 = subMats[i];
    const lv2html = lv2.length
      ? `<div class="itn-row" data-row="2" data-parent="${mat.id}">${lv2.map(s=>_itn(s,'lv2')).join('')}</div>`
      : '';
    return `<div style="display:flex;flex-direction:column;align-items:center;gap:0;" data-col="${mat.id}">
      <div class="itn-row" data-row="1">${_itn(mat,'lv1')}</div>
      ${lv2html}
    </div>`;
  }).join('');

  treeEl.innerHTML = `
    <div id="im-tree-canvas-wrap">
      <canvas id="im-tree-canvas"></canvas>
      <div id="im-tree-nodes">
        <div class="itn-row" data-row="0">${_itn(item,'root')}</div>
        <div style="display:flex;gap:4px;align-items:flex-start;">${matCols}</div>
      </div>
    </div>`;

  requestAnimationFrame(() => drawRightAngleTree(item, mats, subMats));
}

function drawRightAngleTree(item, mats, subMats) {
  const wrap   = document.getElementById('im-tree-canvas-wrap');
  const canvas = document.getElementById('im-tree-canvas');
  const nodes  = document.getElementById('im-tree-nodes');
  if (!wrap || !canvas || !nodes) return;

  const W = nodes.offsetWidth;
  const H = nodes.offsetHeight;
  canvas.width  = W;
  canvas.height = H;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';

  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  ctx.strokeStyle = 'rgba(160,140,100,0.55)';
  ctx.lineWidth   = 1.5;
  ctx.setLineDash([]);

  const wR = wrap.getBoundingClientRect();

  function cx(el) {
    const r = el.getBoundingClientRect();
    return r.left + r.width/2 - wR.left;
  }
  function bot(el) {
    return el.getBoundingClientRect().bottom - wR.top;
  }
  function top(el) {
    return el.getBoundingClientRect().top - wR.top;
  }

  const rootEl = nodes.querySelector('[data-row="0"] .itn.root');
  if (!rootEl) return;
  const rootBotX = cx(rootEl);
  const rootBotY = bot(rootEl);
  const lv1Els = [...nodes.querySelectorAll('[data-row="1"] .itn.lv1')];
  if (!lv1Els.length) return;
  const midY = rootBotY + 14;
  const xs   = lv1Els.map(cx);
  const minX = Math.min(...xs);
  const maxX = Math.max(...xs);

  ctx.beginPath();
  ctx.moveTo(rootBotX, rootBotY);
  ctx.lineTo(rootBotX, midY);
  if (lv1Els.length > 1) {
    ctx.moveTo(minX, midY);
    ctx.lineTo(maxX, midY);
  }
  ctx.stroke();

  lv1Els.forEach(el => {
    const x  = cx(el);
    const ty = top(el);
    ctx.beginPath();
    ctx.moveTo(x, midY);
    ctx.lineTo(x, ty);
    ctx.stroke();
  });

  ctx.strokeStyle = 'rgba(130,120,90,0.4)';
  ctx.lineWidth   = 1;

  lv1Els.forEach((lv1El, idx) => {
    const lv2Els = [...(lv1El.closest('[data-col]')?.querySelectorAll('[data-row="2"] .itn.lv2') || [])];
    if (!lv2Els.length) return;

    const lv1BotX = cx(lv1El);
    const lv1BotY = bot(lv1El);
    const midY2   = lv1BotY + 10;
    const xs2     = lv2Els.map(cx);
    const minX2   = Math.min(...xs2);
    const maxX2   = Math.max(...xs2);

    ctx.beginPath();
    ctx.moveTo(lv1BotX, lv1BotY);
    ctx.lineTo(lv1BotX, midY2);
    if (lv2Els.length > 1) {
      ctx.moveTo(minX2, midY2);
      ctx.lineTo(maxX2, midY2);
    }
    ctx.stroke();

    lv2Els.forEach(el => {
      const x  = cx(el);
      const ty = top(el);
      ctx.beginPath();
      ctx.moveTo(x, midY2);
      ctx.lineTo(x, ty);
      ctx.stroke();
    });
  });
}
