<!DOCTYPE html>
{% load static %}
<html lang="ko">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>게임 정보 — DEAI × RIOT</title>
  <link rel="stylesheet" href="{% static 'css/riotInfoPage.css' %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    .section-inner {
      max-width: 100% !important;
      padding-left: 32px !important;
      padding-right: 32px !important;
    }
    .champ-detail-inner {
      display: grid;
      grid-template-columns: 380px 1fr;
    }
    .champ-detail-img {
      position: relative;
      overflow: hidden;
      min-height: 280px;
      background: var(--bg3);
    }
    .champ-detail-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }
    .champ-detail-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent 60%, var(--bg2) 100%);
    }
    @media (max-width: 700px) {
      .champ-detail-inner { grid-template-columns: 1fr; }
      .champ-detail-img   { min-height: 200px; }
    }
    .champ-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(76px, 1fr));
      gap: 6px;
    }
    .champ-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      cursor: pointer;
      padding: 6px 4px;
      border-radius: 4px;
      border: 1px solid transparent;
      background: var(--bg2);
      transition: all .18s;
    }
    .champ-card:hover  { border-color: var(--red); background: var(--bg3); transform: translateY(-2px); }
    .champ-card.selected { border-color: var(--gold); background: var(--gold-dim); }
    .champ-img {
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 3px; overflow: hidden;
      background: var(--bg3); border: 1px solid var(--border); flex-shrink: 0;
    }
    .champ-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .champ-name {
      font-size: 10px; font-weight: 700; letter-spacing: .5px;
      color: var(--text-sub); text-align: center; line-height: 1.2;
      word-break: keep-all; width: 100%;
    }

    /* ── 챔피언 모달 ── */
    #champ-modal-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 2000;
      background: rgba(0,0,0,.82);
      backdrop-filter: blur(6px);
      align-items: center; justify-content: center;
      padding: 20px;
      animation: cmFadeIn .18s ease;
    }
    #champ-modal-overlay.open { display: flex; }
    @keyframes cmFadeIn { from{opacity:0} to{opacity:1} }
    #champ-modal {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 6px;
      width: 100%; max-width: 900px;
      max-height: 90vh; overflow: hidden;
      display: flex; flex-direction: column;
      animation: cmSlideUp .22s ease;
      position: relative;
    }
    @keyframes cmSlideUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
    .cm-header {
      display: grid; grid-template-columns: 320px 1fr;
      position: relative; min-height: 200px; flex-shrink: 0;
    }
    .cm-splash { position: relative; overflow: hidden; background: var(--bg3); }
    .cm-splash img { width:100%; height:100%; object-fit:cover; object-position:center 15%; display:block; }
    .cm-splash-overlay {
      position:absolute; inset:0;
      background:linear-gradient(90deg, transparent 50%, var(--bg2) 95%);
    }
    .cm-info { padding:28px 32px 20px; display:flex; flex-direction:column; justify-content:center; gap:8px; }
    .cm-position-badge { font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--red-light); }
    .cm-champ-name { font-size:36px; font-weight:700; letter-spacing:2px; color:var(--text-bright); line-height:1; }
    .cm-champ-title { font-size:13px; color:var(--text-muted); letter-spacing:.5px; }
    .cm-champ-desc { font-size:13px; color:var(--text-sub); line-height:1.8; margin-top:4px; }
    .cm-skills { padding:20px 24px 24px; border-top:1px solid var(--border); overflow-y:auto; }
    .cm-skill-tabs { display:flex; gap:10px; margin-bottom:18px; }
    .cm-skill-tab { display:flex; flex-direction:column; align-items:center; gap:5px; cursor:pointer; transition:all .15s; }
    .cm-skill-tab-img { width:56px; height:56px; border-radius:4px; overflow:hidden; border:2px solid var(--border); background:var(--bg3); transition:border-color .15s; }
    .cm-skill-tab-img img { width:100%; height:100%; object-fit:cover; display:block; }
    .cm-skill-tab-key { font-size:10px; font-weight:700; letter-spacing:1.5px; color:var(--text-muted); text-transform:uppercase; }
    .cm-skill-tab.active .cm-skill-tab-img { border-color:var(--red); box-shadow:0 0 10px var(--red-glow); }
    .cm-skill-tab.active .cm-skill-tab-key { color:var(--red); }
    .cm-skill-tab:hover .cm-skill-tab-img { border-color:var(--text-sub); }
    .cm-skill-desc {
      background:var(--bg3); border:1px solid var(--border); border-radius:4px;
      padding:16px 20px; animation:cmFadeIn .15s ease;
      display:grid; grid-template-columns:80px 1fr; gap:16px; align-items:flex-start;
    }
    .cm-skill-icon-box {
      display:flex; flex-direction:column; align-items:center; gap:6px; flex-shrink:0;
    }
    .cm-skill-icon-box img {
      width:64px; height:64px; border-radius:4px; border:2px solid var(--red);
      box-shadow:0 0 12px var(--red-glow); display:block; object-fit:cover;
    }
    .cm-skill-icon-key {
      font-size:12px; font-weight:700; letter-spacing:2px;
      color:var(--red); text-transform:uppercase;
    }
    .cm-skill-body { min-width:0; }
    .cm-skill-name { font-size:16px; font-weight:700; color:var(--text-bright); margin-bottom:6px; }
    .cm-skill-text { font-size:13px; color:var(--text-sub); line-height:1.8; margin-bottom:10px; }
    .cm-skill-stats { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }
    .cm-skill-stat {
      font-size:11px; font-weight:700; padding:3px 10px; border-radius:3px;
      background:rgba(200,155,60,.12); border:1px solid rgba(200,155,60,.3);
      color:var(--gold);
    }
    .cm-skill-cooldown { background:rgba(96,165,250,.1); border-color:rgba(96,165,250,.3); color:#93c5fd; }
    .cm-skill-cost     { background:rgba(59,130,246,.1); border-color:rgba(59,130,246,.3); color:#7dd3fc; }
    .cm-skill-range    { background:rgba(74,222,128,.1); border-color:rgba(74,222,128,.3); color:#86efac; }
    @media (max-width:600px) {
      .cm-skill-desc { grid-template-columns:1fr; }
      .cm-skill-icon-box { flex-direction:row; justify-content:flex-start; }
    }
    .cm-close { position:absolute; top:14px; right:14px; z-index:10; width:32px; height:32px; border-radius:4px; background:rgba(0,0,0,.5); border:1px solid var(--border); color:var(--text-muted); font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .15s; }
    .cm-close:hover { background:var(--red-dim); border-color:var(--red); color:var(--red-light); }
    @media (max-width:700px) {
      .cm-header { grid-template-columns:1fr; }
      .cm-splash  { min-height:200px; }
      .cm-splash-overlay { background:linear-gradient(to top, var(--bg2) 0%, transparent 60%); }
      .cm-info { padding:20px 16px 16px; }
      .cm-champ-name { font-size:26px; }
      .cm-skill-tab-img { width:48px; height:48px; }
      .cm-skills { padding:16px; }
    }

    /* ── 아이템 모달 ── */
    #item-modal-overlay {
      display:none; position:fixed; inset:0; z-index:2000;
      background:rgba(0,0,0,.82); backdrop-filter:blur(6px);
      align-items:center; justify-content:center;
      padding:20px; animation:cmFadeIn .18s ease;
    }
    #item-modal-overlay.open { display:flex; }
    #item-modal {
      background:var(--bg2); border:1px solid var(--border); border-radius:6px;
      width:100%; max-width:980px; max-height:88vh;
      overflow:hidden; display:flex; flex-direction:column;
      animation:cmSlideUp .22s ease; position:relative;
    }
    /* 모달 헤더 */
    .im-header {
      display:grid; grid-template-columns:160px 1fr;
      border-bottom:1px solid var(--border); flex-shrink:0;
    }
    .im-img-box {
      background:var(--bg3); display:flex; flex-direction:column;
      align-items:center; justify-content:center; gap:10px;
      padding:20px; border-right:1px solid var(--border);
    }
    .im-img-box img {
      width:72px; height:72px; border-radius:6px;
      border:2px solid var(--border); display:block;
    }
    .im-img-price {
      font-size:13px; font-weight:700; color:var(--gold);
      font-family:var(--font-ui); letter-spacing:.5px;
    }
    .im-img-sell {
      font-size:10px; color:var(--text-muted); margin-top:-6px;
    }
    .im-header-info {
      padding:20px 24px; display:flex; flex-direction:column; gap:6px;
    }
    .im-name { font-size:22px; font-weight:700; color:var(--text-bright); letter-spacing:1px; }
    .im-explain { font-size:13px; color:var(--text-sub); line-height:1.6; }
    .im-price-row { display:flex; gap:8px; align-items:center; margin-top:2px; }
    .im-badge {
      font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase;
      padding:2px 8px; border-radius:3px;
    }
    /* 모달 바디 */
    /* ── 모달 바디: 스탯/설명(상단) + 트리(하단) 세로 스택 ── */
    .im-body { display:flex; flex-direction:column; overflow-y:auto; }
    .im-top  { display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid var(--border); }
    .im-left { padding:18px 24px; border-right:1px solid var(--border); display:flex; flex-direction:column; gap:10px; }
    .im-right-stats { padding:18px 24px; display:flex; flex-direction:column; gap:10px; }
    /* 트리 전체 영역 */
    .im-tree-section { padding:20px 24px 24px; }
    .im-section-title {
      font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase;
      color:var(--text-muted); border-bottom:1px solid var(--border); padding-bottom:6px; margin-bottom:16px;
    }
    .im-stat-row { display:flex; justify-content:space-between; align-items:center; padding:4px 0; border-bottom:1px solid rgba(255,255,255,.04); }
    .im-stat-label { font-size:12px; color:var(--text-sub); }
    .im-stat-val   { font-size:13px; font-weight:700; color:var(--red-light); }
    .im-desc-text  { font-size:12px; color:var(--text-sub); line-height:1.8; }
    /* ── 트리: Canvas 기반 직각선 ── */
    #im-tree-canvas-wrap {
      position:relative; width:100%; overflow-x:auto;
    }
    #im-tree-canvas {
      position:absolute; top:0; left:0; pointer-events:none;
    }
    #im-tree-nodes {
      position:relative; display:flex; flex-direction:column;
      align-items:center; gap:0;
    }
    .itn-row {
      display:flex; justify-content:center; align-items:flex-start;
      gap:8px; position:relative;
    }
    .itn {
      display:flex; flex-direction:column; align-items:center; gap:4px;
      cursor:pointer; transition:transform .15s;
      padding:6px; border-radius:4px;
      border:1px solid transparent;
      background:transparent;
      transition:all .15s;
    }
    .itn:hover { transform:translateY(-2px); border-color:var(--border); background:var(--bg3); }
    .itn.root  { cursor:default; }
    .itn.root:hover { transform:none; border-color:transparent; background:transparent; }
    .itn img {
      display:block; border-radius:4px; object-fit:cover;
      border:2px solid var(--border); background:var(--bg3);
      transition:border-color .15s;
    }
    .itn:hover img    { border-color:var(--gold); }
    .itn.root img     { width:60px; height:60px; border:2px solid var(--red); box-shadow:0 0 12px var(--red-glow); }
    .itn.lv1 img      { width:48px; height:48px; border-color:#4a4a4a; }
    .itn.lv2 img      { width:38px; height:38px; border-color:#333; opacity:.9; }
    .itn-price { font-size:11px; font-weight:700; color:var(--gold); text-align:center; white-space:nowrap; }
    .itn-name  { font-size:9px; color:var(--text-muted); text-align:center; max-width:60px; line-height:1.3; word-break:keep-all; }
    .im-close {
      position:absolute; top:12px; right:12px; z-index:10;
      width:30px; height:30px; border-radius:4px;
      background:rgba(0,0,0,.5); border:1px solid var(--border);
      color:var(--text-muted); font-size:15px;
      cursor:pointer; display:flex; align-items:center; justify-content:center;
      transition:all .15s;
    }
    .im-close:hover { background:var(--red-dim); border-color:var(--red); color:var(--red-light); }
    @media (max-width:700px) {
      .im-header { grid-template-columns:1fr; }
      .im-img-box { flex-direction:row; justify-content:flex-start; padding:14px 16px; border-right:none; border-bottom:1px solid var(--border); }
      .im-top  { grid-template-columns:1fr; }
      .im-left { border-right:none; border-bottom:1px solid var(--border); }
    }

    /* ── 발로란트 에이전트 모달 ── */
    #vrt-modal-overlay {
      display:none; position:fixed; inset:0; z-index:2000;
      background:rgba(0,0,0,.88); backdrop-filter:blur(8px);
      align-items:center; justify-content:center;
      padding:20px; animation:cmFadeIn .18s ease;
    }
    #vrt-modal-overlay.open { display:flex; }
    #vrt-modal {
      background:var(--bg2); border:1px solid var(--border-red);
      border-radius:4px; width:100%; max-width:920px; max-height:90vh;
      overflow:hidden; display:flex; flex-direction:column;
      animation:cmSlideUp .22s ease; position:relative;
    }
    /* 모달 상단 - 배경 + 캐릭터 */
    .vm-header {
      display:grid; grid-template-columns:280px 1fr;
      min-height:220px; flex-shrink:0; position:relative; overflow:hidden;
    }
    .vm-portrait-box {
      position:relative; overflow:hidden; background:#111;
      display:flex; align-items:flex-end; justify-content:center;
    }
    .vm-portrait-bg {
      position:absolute; inset:0; opacity:.25; filter:blur(4px);
      background-size:cover; background-position:center;
    }
    .vm-portrait-img {
      position:relative; z-index:1; height:220px; object-fit:contain;
      object-position:bottom center; display:block; filter:drop-shadow(0 4px 20px rgba(0,0,0,.8));
    }
    .vm-info {
      padding:24px 28px; display:flex; flex-direction:column; gap:8px;
      justify-content:center; position:relative; z-index:1;
      border-left:1px solid rgba(255,70,84,.2);
    }
    .vm-info-bg {
      position:absolute; inset:0; z-index:0;
      background:linear-gradient(135deg, rgba(255,70,84,.06) 0%, transparent 60%);
    }
    .vm-role-badge {
      display:inline-flex; align-items:center; gap:6px;
      font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase;
      color:var(--red-light); position:relative; z-index:1;
    }
    .vm-role-badge img { width:16px; height:16px; opacity:.8; }
    .vm-agent-name {
      font-size:34px; font-weight:700; letter-spacing:3px;
      color:var(--text-bright); line-height:1; position:relative; z-index:1;
    }
    .vm-role-desc {
      font-size:12px; color:var(--text-muted); letter-spacing:.5px;
      position:relative; z-index:1; font-style:italic;
    }
    .vm-agent-desc {
      font-size:13px; color:var(--text-sub); line-height:1.7;
      position:relative; z-index:1; margin-top:4px;
    }
    /* 스킬 섹션 */
    .vm-skills { padding:0; border-top:1px solid var(--border); overflow-y:auto; }
    .vm-skill-tabs {
      display:flex; border-bottom:1px solid var(--border); background:var(--bg3);
    }
    .vm-skill-tab {
      flex:1; display:flex; flex-direction:column; align-items:center; gap:6px;
      padding:12px 8px; cursor:pointer; border-bottom:2px solid transparent;
      transition:all .15s; border-right:1px solid var(--border);
    }
    .vm-skill-tab:last-child { border-right:none; }
    .vm-skill-tab:hover { background:var(--bg2); }
    .vm-skill-tab.active { border-bottom-color:var(--red); background:var(--bg2); }
    .vm-skill-tab-icon {
      width:40px; height:40px; border-radius:4px; overflow:hidden;
      background:var(--bg4); border:1px solid var(--border);
      display:flex; align-items:center; justify-content:center;
    }
    .vm-skill-tab-icon img { width:100%; height:100%; object-fit:cover; }
    .vm-skill-tab-key {
      font-size:10px; font-weight:700; letter-spacing:2px;
      color:var(--text-muted); text-transform:uppercase;
    }
    .vm-skill-tab-name { font-size:10px; color:var(--text-sub); text-align:center; }
    .vm-skill-tab.active .vm-skill-tab-key  { color:var(--red); }
    .vm-skill-tab.active .vm-skill-tab-name { color:var(--text-bright); }
    /* 스킬 상세 */
    .vm-skill-detail {
      display:grid; grid-template-columns:64px 1fr;
      gap:16px; padding:20px 24px; align-items:flex-start;
      animation:cmFadeIn .15s ease;
    }
    .vm-skill-detail-icon {
      width:64px; height:64px; border-radius:6px; overflow:hidden;
      background:var(--bg3); border:2px solid var(--red);
      box-shadow:0 0 14px var(--red-glow);
    }
    .vm-skill-detail-icon img { width:100%; height:100%; object-fit:cover; }
    .vm-skill-detail-body { min-width:0; }
    .vm-skill-detail-name { font-size:17px; font-weight:700; color:var(--text-bright); margin-bottom:8px; }
    .vm-skill-detail-desc { font-size:13px; color:var(--text-sub); line-height:1.8; }
    .vm-close {
      position:absolute; top:12px; right:12px; z-index:100;
      width:30px; height:30px; border-radius:4px;
      background:rgba(0,0,0,.6); border:1px solid var(--border);
      color:var(--text-muted); font-size:15px;
      cursor:pointer; display:flex; align-items:center; justify-content:center;
      transition:all .15s;
    }
    .vm-close:hover { background:var(--red-dim); border-color:var(--red); color:var(--red-light); }
    @media (max-width:700px) {
      .vm-header { grid-template-columns:1fr; }
      .vm-portrait-box { min-height:180px; }
      .vm-portrait-img { height:180px; }
      .vm-agent-name { font-size:26px; }
      .vm-skill-tab-name { display:none; }
    }

    /* ══ 발로란트 무기 모달 ══ */
    #wm-overlay {
      display:none; position:fixed; inset:0; z-index:2000;
      background:rgba(0,0,0,.88); backdrop-filter:blur(8px);
      align-items:center; justify-content:center;
      padding:20px; animation:cmFadeIn .18s ease;
    }
    #wm-overlay.open { display:flex; }
    #wm-modal {
      background:var(--bg2); border:1px solid rgba(255,70,84,.25);
      border-radius:6px; width:100%; max-width:860px; max-height:90vh;
      overflow:hidden; display:flex; flex-direction:column;
      animation:cmSlideUp .22s ease; position:relative;
    }
    .wm-header {
      display:grid; grid-template-columns:260px 1fr;
      min-height:200px; flex-shrink:0; border-bottom:1px solid var(--border);
      position:relative; overflow:hidden;
    }
    .wm-img-box {
      background:linear-gradient(135deg,#1a0a0a 0%,#0d0d0d 100%);
      display:flex; align-items:center; justify-content:center;
      padding:28px; border-right:1px solid rgba(255,70,84,.15);
      position:relative;
    }
    .wm-img-box::after {
      content:''; position:absolute; inset:0;
      background:radial-gradient(ellipse at center, rgba(255,70,84,.08) 0%, transparent 70%);
    }
    .wm-img-box img {
      width:100%; max-height:140px; object-fit:contain;
      filter:drop-shadow(0 4px 24px rgba(255,70,84,.3));
      position:relative; z-index:1;
    }
    .wm-info {
      padding:26px 28px; display:flex; flex-direction:column;
      justify-content:center; gap:8px; position:relative;
    }
    .wm-info::before {
      content:''; position:absolute; inset:0;
      background:linear-gradient(135deg, rgba(255,70,84,.05) 0%, transparent 60%);
    }
    .wm-type-badge {
      font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase;
      color:var(--red-light); position:relative;
    }
    .wm-name {
      font-size:32px; font-weight:700; letter-spacing:2px;
      color:var(--text-bright); line-height:1; position:relative;
    }
    .wm-cost-row {
      display:flex; align-items:center; gap:10px; position:relative; margin-top:2px;
    }
    .wm-cost { font-size:15px; font-weight:700; color:var(--gold); letter-spacing:.5px; }
    .wm-cost-free { color:#4caf50; }
    .wm-penetration {
      font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase;
      padding:2px 8px; border-radius:3px;
      background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12);
      color:var(--text-muted);
    }
    .wm-body { display:flex; flex-direction:column; overflow-y:auto; }
