async function openChampModal(champId) {
  const c = LOL_CHAMPS.find(x => x.id === champId);
  if (!c) return;

  const POS_KO = { top:'탑', jungle:'정글', mid:'미드', adc:'원딜', support:'서포터' };
  const overlay = document.getElementById('champ-modal-overlay');

  document.getElementById('cm-splash-img').src = c.splash;
  document.getElementById('cm-position').textContent = (POS_KO[c.position] || '—') + ' · ' + (c.tags[0] || '');
  document.getElementById('cm-name').textContent  = c.name;
  document.getElementById('cm-title').textContent = c.title;
  document.getElementById('cm-desc').textContent  = c.blurb;
  document.getElementById('cm-skill-tabs').innerHTML =
    '<div style="color:var(--text-muted);font-size:12px;padding:8px;">스킬 로딩 중...</div>';
  document.getElementById('cm-skill-desc-box').innerHTML = `
    <div class="cm-skill-icon-box">
      <div style="width:64px;height:64px;border-radius:4px;background:var(--bg4);border:2px solid var(--border);"></div>
      <div class="cm-skill-icon-key">—</div>
    </div>
    <div class="cm-skill-body">
      <div class="cm-skill-name">스킬 로딩 중...</div>
      <div class="cm-skill-text"></div>
    </div>`;
  overlay.classList.add('open');
  try {
    const ver = await fetch('/api/info/version/').then(r=>r.json()).then(d=>d.version);
    const dd  = `https://ddragon.leagueoflegends.com/cdn/${ver}`;
    const res  = await fetch(`${dd}/data/ko_KR/champion/${champId}.json`);
    const data = await res.json();
    const cd   = data.data[champId];

    const KEYS = ['Q', 'W', 'E', 'R'];
    _cmSkills = cd.spells.slice(0, 4).map((sp, i) => {
      const tip = sp.leveltip || {};
      const labels = tip.label || [];
      const effect = sp.effectBurn || [];

      // 데미지 수치 파싱
      const dmgValues = (sp.effectBurn || [])
        .map((v, idx) => v && v !== '0' ? { label: labels[idx] || `수치${idx}`, val: v } : null)
        .filter(Boolean)
        .slice(0, 4);

      // 스케일링 정보)
      const scaling = (sp.vars || []).map(v => {
        const ratio = Array.isArray(v.coeff) ? v.coeff[0] : v.coeff;
        const pct   = Math.round(ratio * 100);
        const key   = v.key === 'spelldamage' ? 'AP' :
                      v.key === 'attackdamage' ? 'AD' :
                      v.key === 'bonusattackdamage' ? '추가 AD' :
                      v.key === 'armor' ? '방어력' :
                      v.key === 'health' ? '체력' :
                      v.key === 'bonushealth' ? '추가 체력' : v.key;
        return pct > 0 ? `+${pct}% ${key}` : null;
      }).filter(Boolean);

      return {
        key       : KEYS[i],
        name      : sp.name,
        img       : `${dd}/img/spell/${sp.image.full}`,
        desc      : sp.description.replace(/<[^>]+>/g, ''),
        cooldown  : sp.cooldownBurn || '',
        cost      : sp.costBurn || '',
        range     : (sp.rangeBurn && sp.rangeBurn !== 'self') ? sp.rangeBurn : '',
        dmgValues,
        scaling,
      };
    });

    renderCmSkillTabs();
    selectCmSkill(0);
  } catch(e) {
    document.getElementById('cm-skill-tabs').innerHTML = '';
    document.getElementById('cm-skill-desc-box').innerHTML =
      `<div style="color:var(--red);font-size:13px;padding:8px;">스킬 데이터를 불러올 수 없습니다: ${e.message}</div>`;
  }
}

function renderCmSkillTabs() {
  document.getElementById('cm-skill-tabs').innerHTML = _cmSkills.map((sk, i) => `
    <div class="cm-skill-tab${i===0?' active':''}" onclick="selectCmSkill(${i})">
      <div class="cm-skill-tab-img">
        <img src="${sk.img}" alt="${sk.name}" loading="lazy" onerror="this.style.opacity='.3'"/>
      </div>
      <div class="cm-skill-tab-key">${sk.key}</div>
    </div>`).join('');
}

function selectCmSkill(idx) {
  const sk = _cmSkills[idx];
  if (!sk) return;
  document.querySelectorAll('.cm-skill-tab').forEach((el, i) => {
    el.classList.toggle('active', i === idx);
  });
  const stats = [];
  if(sk.cost == 0){
    sk.cost = "소모값 없음";
  }
  if (sk.cooldown) stats.push(`<span class="cm-skill-stat cm-skill-cooldown">⏱ 재사용 ${sk.cooldown}s</span>`);
  if (sk.cost)     stats.push(`<span class="cm-skill-stat cm-skill-cost">💧 마나/기력 ${sk.cost}</span>`);
  if (sk.range)    stats.push(`<span class="cm-skill-stat cm-skill-range">📏 사거리 ${sk.range}</span>`);
  sk.dmgValues.forEach(d => {
    stats.push(`<span class="cm-skill-stat">⚔ ${d.label}: ${d.val}</span>`);
  });
  sk.scaling.forEach(s => {
    stats.push(`<span class="cm-skill-stat">${s}</span>`);
  });

  document.getElementById('cm-skill-desc-box').innerHTML = `
    <div class="cm-skill-icon-box">
      <img src="${sk.img}" alt="${sk.name}" onerror="this.style.opacity='.3'"/>
      <div class="cm-skill-icon-key">${sk.key}</div>
    </div>
    <div class="cm-skill-body">
      <div class="cm-skill-name">${sk.name}</div>
      <div class="cm-skill-text">${sk.desc}</div>
      ${stats.length ? `<div class="cm-skill-stats">${stats.join('')}</div>` : ''}
    </div>`;
}
