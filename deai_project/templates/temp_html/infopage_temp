let VRT_AGENTS = [];
let vrtRoleFilter = 'all';
const ROLE_KO = {
  'Duelist'   : '타격대',
  'Initiator' : '척후대',
  'Controller': '전략가',
  'Sentinel'  : '감시자',
};
const ROLE_DESC = {
  'Duelist'   : '섬광·이동기로 사이트 진입을 주도하고 킬을 따는 1선 역할',
  'Initiator' : '정보 수집·섬광·스턴으로 팀의 진입을 보조하는 역할',
  'Controller': '연막으로 적 시야를 차단해 전장 구역을 통제하는 역할',
  'Sentinel'  : '덫·트랩으로 사이트를 수비하고 뒤치기를 방어하는 역할',
};

async function loadVrtAgents() {
  if (VRT_AGENTS.length > 0) return;
  showLoading('vrt-agent-grid');
  try {
    const [resKo, resEn] = await Promise.all([
      fetch('https://valorant-api.com/v1/agents?isPlayableCharacter=true&language=ko-KR'),
      fetch('https://valorant-api.com/v1/agents?isPlayableCharacter=true&language=en-US'),
    ]);
    const dataKo = await resKo.json();
    const dataEn = await resEn.json();
    if (dataKo.status !== 200) throw new Error('API 오류');

    const roleEnMap = {};
    (dataEn.data || []).forEach(a => { roleEnMap[a.uuid] = a.role?.displayName || 'Unknown'; });
    const data = dataKo;
    VRT_AGENTS = data.data.map(a => ({
      uuid     : a.uuid,
      name     : a.displayName,
      role     : roleEnMap[a.uuid] || 'Unknown',
      roleKo   : ROLE_KO[roleEnMap[a.uuid]] || a.role?.displayName || '—',
      roleIcon : a.role?.displayIcon || '',
      desc     : a.description,
      icon     : a.displayIcon,
      bust     : a.bustPortrait  || a.fullPortrait || a.displayIcon,
      portrait : a.fullPortrait  || a.displayIcon,
      bg       : a.background    || '',
      bgColor  : a.backgroundGradientColors || [],
      abilities: (a.abilities || []).filter(ab => ab.slot !== 'Passive').map(ab => ({
        slot : ab.slot,
        key  : ab.slot === 'Ability1' ? 'Q' : ab.slot === 'Ability2' ? 'E' : ab.slot === 'Grenade' ? 'C' : ab.slot === 'Ultimate' ? 'X' : ab.slot,
        name : ab.displayName,
        desc : ab.description || '',
        icon : ab.displayIcon || '',
      })),
    }));
    VRT_AGENTS.sort((a,b) => a.name.localeCompare(b.name, 'ko'));
    renderVrtAgents();
  } catch(e) {
    showError('vrt-agent-grid', '에이전트 데이터 로드 실패: ' + e.message);
  }
}
function filterVrtRole(role, btn) {
  vrtRoleFilter = role;
  setActiveFilter(document.getElementById('vrt-role-filters'), btn);
  if (VRT_AGENTS.length === 0) { loadVrtAgents(); return; }
  renderVrtAgents();
}
function renderVrtAgents() {
  const grid = document.getElementById('vrt-agent-grid');
  const filtered = vrtRoleFilter === 'all'
    ? VRT_AGENTS
    : VRT_AGENTS.filter(a => a.role === vrtRoleFilter);
  grid.innerHTML = filtered.map(a => `
    <div class="champ-card" onclick="openVrtModal('${a.uuid}')">
      <div class="champ-img">
        <img src="${a.icon}" alt="${a.name}" loading="lazy"
             onerror="this.style.opacity='.3'"/>
      </div>
      <div class="champ-name">${a.name}</div>
    </div>`).join('');
}

let VRT_WEAPONS = [];
let vrtWeaponFilter = 'all';
const WEAPON_CAT_KO = {
  'rifle':'rifle', 'sniper':'sniper', 'smg':'smg',
  'shotgun':'shotgun', 'sidearm':'pistol', 'heavy':'heavy', 'melee':'melee'
};

async function loadVrtWeapons() {
  if (VRT_WEAPONS.length > 0) return;
  showLoading('vrt-weapon-grid');
  try {
    const res  = await fetch('https://valorant-api.com/v1/weapons?language=ko-KR');
    const data = await res.json();
    if (data.status !== 200) throw new Error('API 오류');
    VRT_WEAPONS = data.data
      .filter(w => !w.category?.toLowerCase().includes('melee'))
      .map(w => {
        const catRaw  = (w.category?.replace(/EEquippableCategory::/i,'') || '').trim().toLowerCase();
        const typeKey = WEAPON_CAT_KO[catRaw] || catRaw;
        const dmg     = w.weaponStats?.damageRanges?.[0];
        const dmgText = dmg
          ? `헤드: ${dmg.headDamage} / 몸통: ${dmg.bodyDamage}`
          : '—';
        return {
          uuid     : w.uuid,
          name     : w.displayName,
          type     : typeKey,
          typeText : w.shopData?.categoryText || '',
          cost     : w.shopData?.cost || 0,
          dmg      : dmgText,
          fireRate : w.weaponStats?.fireRate || 0,
          magazine : w.weaponStats?.magazineSize || 0,
          reload   : w.weaponStats?.reloadTimeSeconds || 0,
          equip    : w.weaponStats?.equipTimeSeconds || 0,
          accuracy : w.weaponStats?.firstBulletAccuracy || 0,
          wallPen  : (w.weaponStats?.wallPenetration || '').replace('EWallPenetrationDisplayType::',''),
          damageRanges: w.weaponStats?.damageRanges || [],
          img      : w.displayIcon,
          shopImg  : w.shopData?.newImage || w.displayIcon,
        };
      });
    VRT_WEAPONS.sort((a,b) => b.cost - a.cost);
    renderVrtWeapons();
  } catch(e) {
    showError('vrt-weapon-grid', '무기 데이터 로드 실패: ' + e.message);
  }
}
function filterVrtWeapon(type, btn) {
  vrtWeaponFilter = type;
  setActiveFilter(document.getElementById('vrt-weapon-filters'), btn);
  renderVrtWeapons();
}
function renderVrtWeapons() {
  const grid     = document.getElementById('vrt-weapon-grid');
  const filtered = vrtWeaponFilter === 'all'
    ? VRT_WEAPONS
    : VRT_WEAPONS.filter(w => w.type === vrtWeaponFilter);
  const TYPE_KO = { rifle:'라이플', sniper:'스나이퍼', smg:'SMG', shotgun:'샷건', pistol:'권총', heavy:'헤비' };
  grid.innerHTML = filtered.map(w => `
    <div class="item-card" onclick="openWeaponModal('${w.uuid}')" style="cursor:pointer;">
      <div class="item-img" style="background:var(--bg3);display:flex;align-items:center;justify-content:center;">
        <img src="${w.img}" alt="${w.name}" loading="lazy"
             style="width:100%;height:100%;object-fit:contain;padding:6px;"
             onerror="this.parentElement.innerHTML='🔫'"/>
      </div>
      <div class="item-info">
        <div class="item-name">${w.name}</div>
        <div class="item-type">${TYPE_KO[w.type]||w.type} · ${w.cost > 0 ? w.cost+'cr' : '무료'}</div>
        <div class="item-stat">${w.dmg}</div>
        <div class="item-desc">연사속도 ${w.fireRate} · 탄창 ${w.magazine}발</div>
      </div>
    </div>`).join('');
}

const WM_PEN_KO  = { Low:'낮음', Medium:'중간', High:'높음' };
const WM_TYPE_KO = { rifle:'라이플', sniper:'스나이퍼', smg:'SMG', shotgun:'샷건', pistol:'권총', heavy:'헤비' };

function openWeaponModal(uuid) {
  const w = VRT_WEAPONS.find(x => x.uuid === uuid);
  if (!w) return;

  // 헤더
  document.getElementById('wm-img').src  = w.shopImg || w.img;
  document.getElementById('wm-img').alt  = w.name;
  document.getElementById('wm-type').textContent = WM_TYPE_KO[w.type] || w.type;
  document.getElementById('wm-name').textContent = w.name;

  const costEl = document.getElementById('wm-cost');
  if (w.cost === 0) {
    costEl.textContent = '무료';
    costEl.className = 'wm-cost wm-cost-free';
  } else {
    costEl.textContent = w.cost.toLocaleString() + ' cr';
    costEl.className = 'wm-cost';
  }
  document.getElementById('wm-pen').textContent = '관통 ' + (WM_PEN_KO[w.wallPen] || w.wallPen);

  document.getElementById('wm-stats').innerHTML = [
    { label:'연사속도',   val: w.fireRate,  unit:'발/초' },
    { label:'탄창',       val: w.magazine,  unit:'발' },
    { label:'재장전',     val: w.reload,    unit:'초' },
    { label:'장착 시간',  val: w.equip,     unit:'초' },
    { label:'정확도',     val: (w.accuracy * 100).toFixed(0), unit:'%' },
  ].map(s => `
    <div class="wm-stat-card">
      <div class="wm-stat-label">${s.label}</div>
      <div class="wm-stat-val">${s.val}<span class="wm-stat-unit"> ${s.unit}</span></div>
    </div>`).join('');

  const rows = w.damageRanges.map(r => `
    <tr>
      <td class="wm-dmg-range">${r.rangeStartMeters}–${r.rangeEndMeters}m</td>
      <td class="wm-dmg-head">${r.headDamage}</td>
      <td class="wm-dmg-body">${r.bodyDamage}</td>
