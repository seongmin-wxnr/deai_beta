<script>
function showGame(game, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('section-' + game).classList.add('active');
  document.querySelectorAll('.game-tab').forEach(t => t.classList.remove('active'));
  const tab = document.querySelector('.game-tab.' + game);
  if (tab) tab.classList.add('active');
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  if (el && el.classList.contains('nav-link')) el.classList.add('active');
  document.querySelector('.game-tabs').scrollIntoView({ behavior:'smooth', block:'start' });
  // 탭별 데이터 지연 로드
  if (game === 'lol') { loadLolChamps(); loadLolItems(); }
  else if (game === 'vrt') { loadVrtAgents(); loadVrtWeapons(); }
  else if (game === 'tft') { /* 서브탭 전환 시 로드 */ }
}

function setActiveFilter(container, clicked) {
  container.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  clicked.classList.add('active');
}
function showLoading(gridId) {
  document.getElementById(gridId).innerHTML =
    '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);font-size:13px;letter-spacing:1px;">로딩 중...</div>';
}
function showError(gridId, msg) {
  document.getElementById(gridId).innerHTML =
    `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--red);font-size:13px;">${msg}</div>`;
}

