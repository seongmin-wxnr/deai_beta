      ${s.intro ? `<div class="syn-desc">${s.intro.replace(/\n/g,'<br>')}</div>` : ''}
      ${tierRows ? `<div class="syn-tiers">${tierRows}</div>` : ''}
      <div class="syn-champs">${champPortraits}</div>
    </div>`;
  }).join('') ||
  '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);font-size:13px;">해당 시너지가 없습니다.</div>';
}

let TFT_CHAMPS = [];
let tftCostFilter = 'all';
// CDragon/ddragon 모두 7코스트를 cost=5로 잘못 저장 → apiName 기준 수동 매핑
const TFT16_COST7 = new Set([
  'TFT16_Galio',       // 갈리오
  'TFT16_BaronNashor', // 내셔 남작
  'TFT16_Ryze',        // 라이즈
  'TFT16_Lucian',      // 루시안과 세나
  'TFT16_Volibear',    // 볼리베어
  'TFT16_Brock',       // 브록
  'TFT16_Sylas',       // 사일러스
]);

const COST_COLORS = { 1:'#9e9e9e', 2:'#4caf50', 3:'#29b6f6', 4:'#ab47bc', 5:'#f9a825', 7:'#f44336' };

// ══════════════════════════════════════════
// TFT 챔피언 모달 (Community Dragon) — 선언 순서 중요: loadTftChamps보다 먼저
// ══════════════════════════════════════════
let _tcCDragon   = null;   // apiName → champion 맵
let _cdFullData  = null;   // CDragon 전체 JSON (traits 등에서 재사용)

const TC_IMG = path => path
  ? 'https://raw.communitydragon.org/latest/game/' +
    path.toLowerCase().replace(/^\/game\//,'').replace(/\.(tex|dds)$/,'.png')
  : '';

async function _loadCDragon() {
  if (_tcCDragon) return;
  try {
    const res  = await fetch('https://raw.communitydragon.org/latest/cdragon/tft/ko_kr.json');
    const data = await res.json();
    _cdFullData = data;   // 전체 JSON 캐시
    const champs = (data.sets?.['16']?.champions || [])
      .filter(c => c.cost >= 1 && c.cost <= 7 && c.apiName?.startsWith('TFT16_'));
    _tcCDragon = {};
    champs.forEach(c => { _tcCDragon[c.apiName] = c; });
  } catch(e) {
    console.warn('[TCM] CDragon 로드 실패:', e.message);
    _tcCDragon  = {};
    _cdFullData = {};
  }
}

async function loadTftChamps() {
  if (TFT_CHAMPS.length > 0) return;
  showLoading('tft-champ-grid');
  try {
    // CDragon만 사용 — 이미지·cost·traits 모두 CDragon 기준
    await _loadCDragon();
    if (!_tcCDragon || Object.keys(_tcCDragon).length === 0) throw new Error('CDragon 데이터 없음');

    TFT_CHAMPS = Object.values(_tcCDragon).map(c => ({
      id    : c.apiName,
      name  : c.name,
      // CDragon/ddragon 모두 7코스트를 5로 잘못 저장 → 수동 보정
      cost  : TFT16_COST7.has(c.apiName) ? 7 : c.cost,
      traits: c.traits || [],
      img   : TC_IMG(c.squareIcon || c.tileIcon),
    }));
    TFT_CHAMPS.sort((a, b) => a.cost - b.cost || a.name.localeCompare(b.name, 'ko'));
    renderTftChamps();
  } catch(e) {
    showError('tft-champ-grid', 'TFT 챔피언 로드 실패: ' + e.message);
  }
}
function filterTftCost(cost, btn) {
  tftCostFilter = cost;
  setActiveFilter(document.getElementById('tft-cost-filters'), btn);
  renderTftChamps();
}
function renderTftChamps() {
  const grid     = document.getElementById('tft-champ-grid');
  const filtered = tftCostFilter === 'all'
    ? TFT_CHAMPS
    : TFT_CHAMPS.filter(c => c.cost === tftCostFilter);
  grid.innerHTML = filtered.map(c => {
    const col = COST_COLORS[c.cost] || '#9e9e9e';
    return `
    <div class="champ-card" onclick="selectTftChamp('${c.id}')" style="border-bottom:2px solid ${col}33;">
      <div class="champ-img" style="border-color:${col}44;">
        <img src="${c.img}" alt="${c.name}" loading="lazy"
             onerror="this.style.opacity='.3'"/>
      </div>
      <div class="champ-name" style="color:${col};">${c.name}</div>
    </div>`;
  }).join('');
}
async function selectTftChamp(id) {
  // 카드 selected 처리 (event 캡처를 async 이전에)
  const clickedCard = event.currentTarget;
  document.querySelectorAll('#tft-champ-grid .champ-card').forEach(el => el.classList.remove('selected'));
  if (clickedCard) clickedCard.classList.add('selected');

  const c = TFT_CHAMPS.find(x => x.id === id);
  if (!c) return;

  // 모달 즉시 열고 로딩 상태 표시
  const col = COST_COLORS[c.cost] || '#9e9e9e';
  document.getElementById('tcm-cost-badge').textContent  = `${c.cost}코스트`;
  document.getElementById('tcm-cost-badge').style.color  = col;
  document.getElementById('tcm-name').textContent        = c.name;
  document.getElementById('tcm-traits').innerHTML        = c.traits.map(t =>
    `<span class="tcm-trait-chip">${t}</span>`).join('');
  document.getElementById('tcm-splash').src              = c.img;
  document.getElementById('tcm-splash').style.borderBottom = `3px solid ${col}`;
  document.getElementById('tcm-stats').innerHTML =
    '<div style="color:var(--text-muted);font-size:12px;grid-column:1/-1">로딩 중...</div>';
  document.getElementById('tcm-ability-name').textContent = '로딩 중...';
  document.getElementById('tcm-ability-desc').textContent = '';
  document.getElementById('tcm-ability-icon').src = '';
  document.getElementById('tcm-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';

  // Community Dragon 데이터 로드 후 채우기
  await _loadCDragon();
  const cd = _tcCDragon?.[id] || null;

  // ── 스탯 ──
  const STAT_DEF = [
    { key:'hp',           label:'체력',       unit:'' },
    { key:'damage',       label:'공격력',     unit:'' },
    { key:'armor',        label:'방어력',     unit:'' },
    { key:'magicResist',  label:'마법 저항',  unit:'' },
    { key:'attackSpeed',  label:'공격속도',   unit:'' },
    { key:'mana',         label:'마나',        unit:'' },
    { key:'initialMana',  label:'초기 마나',  unit:'' },
    { key:'range',        label:'사거리',     unit:'' },
  ];
  const stats = cd?.stats || {};
  document.getElementById('tcm-stats').innerHTML = STAT_DEF
    .filter(s => stats[s.key] != null && stats[s.key] !== 0)
    .map(s => {
      const raw = stats[s.key];
      const val = s.key === 'attackSpeed'
        ? raw.toFixed(2)
        : Math.round(raw * 10) / 10;
      return `
      <div class="tcm-stat-card">
        <div class="tcm-stat-label">${s.label}</div>
        <div class="tcm-stat-val">${val}<span class="tcm-stat-unit">${s.unit}</span></div>
      </div>`;
    }).join('') ||
    '<div style="color:var(--text-muted);font-size:12px;grid-column:1/-1">스탯 정보 없음</div>';

  // ── 스킬 ──
  const ab = cd?.ability;
  if (ab) {
    const iconUrl = TC_IMG(ab.icon);
    document.getElementById('tcm-ability-icon').src       = iconUrl;
    document.getElementById('tcm-ability-name').textContent = ab.name || '—';
    // 스킬 설명 태그 정리
    const desc = (ab.desc || '')
      .replace(/<[^>]+>/g, '')
      .replace(/\(%i:[^)]+\)/g, '')
      .replace(/@\w+@/g, '?')
      .trim();
    document.getElementById('tcm-ability-desc').textContent = desc || '설명 없음';
  } else {
    // CDragon에 없으면 ddragon 이미지라도 표시
    document.getElementById('tcm-ability-icon').src       = c.img;
    document.getElementById('tcm-ability-name').textContent = '스킬 정보 없음';
    document.getElementById('tcm-ability-desc').textContent = '';
  }

  // 스플래시: CDragon tileIcon이 있으면 교체
  if (cd?.tileIcon) {
    document.getElementById('tcm-splash').src = TC_IMG(cd.tileIcon);
  }
}

