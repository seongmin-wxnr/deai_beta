// ══════════════════════════════════════════
// TFT 시너지 (ddragon traits)
// ══════════════════════════════════════════
let TFT_SYNERGIES = [];
let tftSynFilter  = 'all';

// Set 16 기준 직업/계열 분류 (ddragon에서 type 필드가 없어 이름으로 판별)
// ddragon trait에는 type 없음 → 챔피언 수가 적으면 계열, 많으면 직업으로 단순 분류
async function loadTftSynergies() {
  if (TFT_SYNERGIES.length > 0) return;
  showSynLoading();
  try {
    // _loadCDragon()에서 이미 전체 JSON을 _cdFullData에 캐싱 → 재fetch 불필요
    await _loadCDragon();
    const data   = _cdFullData || {};
    const set16     = data.sets?.['16'] || {};
    const cdTraits  = set16.traits   || [];
    const cdChamps  = set16.champions || [];

    // 챔피언 맵 (name → {img, cost})
    const champMap = {};
    cdChamps.forEach(c => {
      if (!c.apiName?.startsWith('TFT16_')) return;
      const cost = TFT16_COST7.has(c.apiName) ? 7 : (c.cost || 1);
      champMap[c.name] = { img: TC_IMG(c.squareIcon || c.tileIcon), cost };
    });

    // 특성 → 챔피언 목록 맵
    const traitChampMap = {};
    cdChamps.forEach(c => {
      if (!c.apiName?.startsWith('TFT16_')) return;
      const cost = TFT16_COST7.has(c.apiName) ? 7 : (c.cost || 1);
      (c.traits || []).forEach(t => {
        if (!traitChampMap[t]) traitChampMap[t] = [];
        traitChampMap[t].push({ name: c.name, img: champMap[c.name]?.img || '', cost });
      });
    });

    // style 값 → 등급 명
    const STYLE_CLASS = { 1:'bronze', 3:'silver', 4:'gold', 5:'chroma', 6:'unique' };
    const STYLE_LABEL = { 1:'브론즈', 3:'실버', 4:'골드', 5:'프리즘', 6:'특수' };

    // %i:scaleXX% 아이콘 → 한국어 단위 기호
    const ICON_MAP = {
      '%i:scaleAD%' : '공격력',
      '%i:scaleAP%': '주문력',
      '%i:scaleAS%' : '공격속도',
      '%i:scaleArmor%': '방어력 ,',
      '%i:scaleMR%': '마법 저항',
      '%i:scaleHealth%': '체력',
      '%i:scaleDA%' : '피해 증폭',
      '%i:scaleDR%' : '피해 감소',
      '%i:scaleCrit%' : '치명타',
      '%i:scaleCritMult%': '치명타 피해',
      '%i:scaleSV%' : '주문 흡혈',
      '%i:scaleSouls%': '영혼',
      '%i:scaleSerpents%': '뱀',
      '%i:Set16Ixtal%' : '이쉬탈',
    };

    // 변수 치환 헬퍼
    const applyVars = (tmpl, vars, minUnits) => tmpl.replace(/@([^@]+)@/g, (_, expr) => {
      if (expr.includes('.') || expr.includes(':')) return '';
      if (expr === 'MinUnits') return String(minUnits ?? '?');
      const m = expr.match(/^(.+?)\*(\d+(?:\.\d+)?)$/);
      if (m) {
        if (m[1] === 'MinUnits') return String(Math.round((minUnits ?? 0) * parseFloat(m[2])));
        const v = vars[m[1]];
        return v != null ? String(Math.round(v * parseFloat(m[2]))) : '?';
      }
      const v = vars[expr];
      if (v == null) return expr;
      return Number.isInteger(v) ? String(v) : String(Math.round(v * 100) / 100);
    });

    // 아이콘 + 불필요 태그 정리
    const cleanLine = s => {
      Object.entries(ICON_MAP).forEach(([k, v]) => {
        s = s.replace(new RegExp(k.replace(/[%:]/g, '\\$&'), 'g'), v);
      });
      return s.replace(/\(%i:[^)]+\)/g, '').replace(/%i:[^\s%]+%/g, '')
              .replace(/<[^>]+>/g, '').replace(/^\(\d+\)\s*/, '').trim();
    };

    // desc 파싱 — 3가지 패턴 처리
    // 반환: { intro, tierLines }
    const parseDesc = (raw, effects) => {
      if (!raw) return { intro: '', tierLines: [] };

      // 1) <expandRow> 하나 → 모든 effect에 동일 템플릿 적용
      const expandM = raw.match(/<expandRow>([\s\S]*?)<\/expandRow>/i);

      // 2) <row> 여러 개 → 각 row를 각 effect에 1:1 매핑
      const allRows = [...raw.matchAll(/<row>([\s\S]*?)<\/row>/gi)].map(m => m[1]);

      // intro: 템플릿 태그들 제거 후 정리
      let intro = raw
        .replace(/<expandRow>[\s\S]*?<\/expandRow>/gi, '')
        .replace(/<row>[\s\S]*?<\/row>/gi, '')
        .replace(/<rules>[\s\S]*?<\/rules>/gi, '')
        .replace(/<br\s*\/?>/gi, '\n')
        .replace(/<[^>]+>/g, '')
        .replace(/@([^@]+)@/g, (_, expr) => {
          if (expr.includes('.') || expr.includes(':')) return '';
          if (expr === 'MinUnits') return effects?.length ? String(effects[0].minUnits) : '';
          const m = expr.match(/^(.+?)\*(\d+(?:\.\d+)?)$/);
          if (m && effects?.length) {
            const v = effects[0].variables?.[m[1]];
            return v != null ? String(Math.round(v * parseFloat(m[2]))) : '';
          }
          if (effects?.length) {
            const v = effects[0].variables?.[expr];
            return v != null ? (Number.isInteger(v) ? String(v) : String(Math.round(v * 100) / 100)) : '';
          }
          return '';
        });
      Object.entries(ICON_MAP).forEach(([k, v]) => {
        intro = intro.replace(new RegExp(k.replace(/[%:]/g, '\\$&'), 'g'), v);
      });
      intro = intro.replace(/\(%i:[^)]+\)/g, '').replace(/%i:[^\s%]+%/g, '')
                   .replace(/\n{3,}/g, '\n\n').trim();

      let tierLines = [];

      if (expandM && effects?.length) {
        // expandRow: 1 템플릿 × N effects
        const tmpl = expandM[1];
        const lines = effects.map(e => cleanLine(applyVars(tmpl, e.variables || {}, e.minUnits)));
        // 중복 제거: 모든 줄이 동일하면 1개만
        const unique = [...new Set(lines)];
        tierLines = unique.length === 1 ? [] : lines;  // 중복이면 intro만으로 충분
        if (unique.length === 1) intro = intro || unique[0]; // intro가 없으면 추가
      } else if (allRows.length > 0 && effects?.length) {
        if (allRows.length === effects.length) {
          // row N개 = effect N개: 각각 매핑
          tierLines = allRows.map((rowTmpl, i) => {
            const e = effects[i];
            return cleanLine(applyVars(rowTmpl, e.variables || {}, e.minUnits));
          });
        } else if (allRows.length === 1) {
          // row 1개: expandRow처럼 처리
          const tmpl = allRows[0];
          const lines = effects.map(e => cleanLine(applyVars(tmpl, e.variables || {}, e.minUnits)));
          const unique = [...new Set(lines)];
          tierLines = unique.length === 1 ? [] : lines;
          if (unique.length === 1 && !intro.includes(unique[0])) intro = (intro + '\n' + unique[0]).trim();
        } else {
          // row 수 ≠ effect 수: row들을 intro 뒤에 붙임
          const rowText = allRows.map(r => cleanLine(applyVars(r, effects[0]?.variables || {}, effects[0]?.minUnits))).join('\n');
          intro = (intro + (intro ? '\n\n' : '') + rowText).trim();
        }
      }

      return { intro, tierLines };
    };

    TFT_SYNERGIES = cdTraits
      .filter(t => t.apiName?.startsWith('TFT16_') && !t.apiName.includes('Teamup') && t.name)
      .map(t => {
        const champs  = (traitChampMap[t.name] || [])
          .sort((a, b) => a.cost - b.cost || a.name.localeCompare(b.name, 'ko'));
        const synType = champs.length >= 6 ? 'class' : 'origin';
        const icon    = TC_IMG(t.icon || '');
        const { intro, tierLines } = parseDesc(t.desc, t.effects);
        const tiers = (t.effects || []).map((e, i) => ({
          need  : e.minUnits,
          style : STYLE_CLASS[e.style] || 'bronze',
          label : STYLE_LABEL[e.style] || '브론즈',
          // expandRow 치환 결과가 있으면 그걸, 없으면 label만
          desc  : tierLines[i] || '',
        }));
        return { key: t.apiName, name: t.name, icon, synType, intro, champs, tiers };
      })
      .filter(t => t.champs.length > 0)
      .sort((a, b) => a.name.localeCompare(b.name, 'ko'));

    renderTftSynergies();
  } catch(e) {
    document.getElementById('tft-syn-grid').innerHTML =
      `<div style="color:var(--red);padding:20px;font-size:13px;">시너지 로드 실패: ${e.message}</div>`;
  }
}

