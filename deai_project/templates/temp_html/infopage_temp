function getChampPosition(champId) {
  if (LOL_POSITION_MAP[champId]) return LOL_POSITION_MAP[champId];
  const clean = champId.replace(/[^a-zA-Z]/g, '');
  if (LOL_POSITION_MAP[clean]) return LOL_POSITION_MAP[clean];
  return null; // 매핑 없으면 '전체'에만 표시
}

let LOL_CHAMPS = [];
let lolClassFilter = 'all';

async function loadLolChamps() {
  if (LOL_CHAMPS.length > 0) return;
  showLoading('lol-champ-grid');
  try {
    const res  = await fetch('/api/info/lol/champions/?lang=ko_KR&_=' + Date.now());
    const data = await res.json();
    if (!data.success) throw new Error(data.message);
    // 포지션 필드 추가
    LOL_CHAMPS = data.champions.map(c => ({
      ...c,
      position: getChampPosition(c.id),
    }));
    renderLolChamps();
  } catch(e) {
    showError('lol-champ-grid', '챔피언 데이터 로드 실패: ' + e.message);
  }
}
function filterLolClass(pos, btn) {
  lolClassFilter = pos;
  setActiveFilter(document.getElementById('lol-class-filters'), btn);
  renderLolChamps();
}
function renderLolChamps() {
  const grid = document.getElementById('lol-champ-grid');
  const POS_KO = { top:'탑', jungle:'정글', mid:'미드', adc:'원딜', support:'서포터' };
  const filtered = lolClassFilter === 'all'
    ? LOL_CHAMPS
    : LOL_CHAMPS.filter(c => c.position === lolClassFilter);
  grid.innerHTML = filtered.map(c => `
    <div class="champ-card" onclick="openChampModal('${c.id}')">
      <div class="champ-img">
